# ==============================
# Trexu Bot Environment Template
# ==============================
# این فایل نمونه است.
# آن را به .env کپی کن و مقدارها را پر کن.

# ------------------------------
# 1) Telegram
# ------------------------------
# توکن ربات از BotFather
BOT_TOKEN=123456789:YOUR_BOT_TOKEN

# آیدی عددی ادمین‌ها، با کاما جدا شوند
ADMIN_IDS=123456789,987654321

# ------------------------------
# 2) Database
# ------------------------------
# برای Termux و اجرای ساده:
DATABASE_URL=sqlite:///trexu.db

# نمونه PostgreSQL برای هاست:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# ------------------------------
# 3) Music Recognition / Lyrics
# ------------------------------
# توکن AudD برای تشخیص آهنگ
AUDD_API_TOKEN=

# توکن Genius برای جستجوی متن / متادیتا
GENIUS_API_TOKEN=

# ------------------------------
# 4) Public Bot Info
# ------------------------------
# لینک کانال رسمی ربات
CHANNEL_URL=https://t.me/your_channel

# آیدی پشتیبانی
SUPPORT_USERNAME=@your_support

# ------------------------------
# 5) Manual Payment
# ------------------------------
BANK_CARD_NUMBER=6037-0000-0000-0000
BANK_CARD_HOLDER=Your Full Name

# ------------------------------
# 6) Free / VIP Limits
# ------------------------------
FREE_DAILY_LIMIT=5
FREE_AD_INTERVAL=3

VIP_1M_PRICE=199000
VIP_3M_PRICE=499000
VIP_12M_PRICE=1599000

# ------------------------------
# 7) Runtime / Queue / Cleanup
# ------------------------------
FORCE_JOIN_SKIP_ADMINS=true
MAX_FILE_AGE_DAYS=2
REQUEST_TIMEOUT=120
DOWNLOAD_WORKERS=2
BOT_NAME=Trexu Bot
DEFAULT_LANG=fa

# ------------------------------
# 8) Local Storage
# ------------------------------
DOWNLOAD_DIR=./data/downloads
TEMP_DIR=./data/temp

# ------------------------------
# 9) Optional: network helpers
# ------------------------------
# اگر بعضی لینک‌ها نیاز به کوکی داشته باشند
YT_DLP_COOKIE_FILE=

# اگر شبکه محدود باشد می‌توانی پراکسی بدهی
PROXY_URL=
